+
+    // Front-aware damping: if one side is very shallow, smoothly reduce flux
+    // magnitude to avoid overshoot and oscillations at the wetting front.
+    if (shallow_damping_depth > h_min) {
+        double hL_eff = fmax(h_min, rs.hL_star);
+        double hR_eff = fmax(h_min, rs.hR_star);
+        double h_min_side = fmin(hL_eff, hR_eff);
+        if (h_min_side < shallow_damping_depth) {
+            double t = (h_min_side - h_min) /
+                       (shallow_damping_depth - h_min);
+            t = fmin(1.0, fmax(0.0, t));
+            // Use a smoother cubic taper near dryness.
+            double scale = t * t * (3.0 - 2.0 * t);
+            flux_fh  *= scale;
+            flux_fhu *= scale;
+            flux_fhv *= scale;
+        }
