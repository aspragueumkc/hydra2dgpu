# HYDRA 2D GPU — C++/CUDA API Reference
# Generated: doxygen -g, then trimmed
# Usage: doxygen Doxyfile  (output: docs/cpp/api/)

PROJECT_NAME           = "HYDRA 2D GPU — C++/CUDA"
PROJECT_NUMBER         = 2.0
PROJECT_BRIEF          = "GPU-Accelerated 2D Shallow Water Equation Solver"
OUTPUT_DIRECTORY       = cpp/api
CREATE_SUBDIRS         = NO
FULL_PATH_NAMES        = NO

# Input
INPUT                  = ../cpp/src ../README.md
FILE_PATTERNS          = *.hpp *.h *.cuh *.cpp *.cu *.md
RECURSIVE              = NO
EXCLUDE                = ../cpp/src/overlay_backend.cpp
EXCLUDE_PATTERNS       =
USE_MDFILE_AS_MAINPAGE = ../README.md

# Extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = YES
SHORT_NAMES            = NO

# Warnings
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = __CUDACC__=1 SWE2D_HOSTDEV=__host__ __device__
SKIP_FUNCTION_MACROS   = NO

# Output
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = .
HTML_EXTRA_STYLESHEET  =
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_TIMESTAMP         = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO

# Diagrams (requires graphviz)
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 5
DOT_TRANSPARENT        = YES

# CUDA support
ALIASES                = "global=\\par GPU kernel:\\n\\par"
ALIASES               += "device=\\par Device function:\\n\\par"
ALIASES               += "host=\\par Host function:\\n\\par"
